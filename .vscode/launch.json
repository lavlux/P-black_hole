{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "OpenGL Debug (AMD)",
            "type": "cppdbg",
            "request": "launch",
            // This matches the output from the task above
            "program": "${fileDirname}/${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/mingw64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            // This MUST match the label in tasks.json
            "preLaunchTask": "Build Black Hole"
        }
    ]
}